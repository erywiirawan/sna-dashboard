{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Dark-themed business intelligence dashboard for PT Saka Niaga Abadi — a building material distributor. Optimized for data density, quick scanning, and professional monitoring.",
  "color": {
    "$type": "color",
    "bg": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.067,
          0.09
        ],
        "hex": "#0f1117"
      }
    },
    "card": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.102,
          0.114,
          0.161
        ],
        "hex": "#1a1d29"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.165,
          0.176,
          0.227
        ],
        "hex": "#2a2d3a"
      }
    },
    "text": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.878,
          0.878,
          0.878
        ],
        "hex": "#e0e0e0"
      }
    },
    "dim": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.533,
          0.533,
          0.667
        ],
        "hex": "#8888aa"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.424,
          0.361,
          0.906
        ],
        "hex": "#6c5ce7"
      }
    },
    "accent2": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.808,
          0.788
        ],
        "hex": "#00cec9"
      }
    },
    "green": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.722,
          0.58
        ],
        "hex": "#00b894"
      }
    },
    "red": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.882,
          0.439,
          0.333
        ],
        "hex": "#e17055"
      }
    },
    "orange": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.992,
          0.796,
          0.431
        ],
        "hex": "#fdcb6e"
      }
    },
    "blue": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.455,
          0.725,
          1
        ],
        "hex": "#74b9ff"
      }
    },
    "purple": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.635,
          0.608,
          0.996
        ],
        "hex": "#a29bfe"
      }
    },
    "header-from": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.102,
          0.114,
          0.161
        ],
        "hex": "#1a1d29"
      }
    },
    "header-to": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.176,
          0.122,
          0.239
        ],
        "hex": "#2d1f3d"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Segoe UI', system-ui, sans-serif",
        "fontSize": {
          "value": 20,
          "unit": "px"
        },
        "fontWeight": 700
      }
    },
    "h3": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Segoe UI', system-ui, sans-serif",
        "fontSize": {
          "value": 13,
          "unit": "px"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0.02,
          "unit": "em"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Segoe UI', system-ui, sans-serif",
        "fontSize": {
          "value": 13,
          "unit": "px"
        },
        "fontWeight": 400
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Segoe UI', system-ui, sans-serif",
        "fontSize": {
          "value": 11,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0.05,
          "unit": "em"
        }
      }
    },
    "value-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Segoe UI', system-ui, sans-serif",
        "fontSize": {
          "value": 22,
          "unit": "px"
        },
        "fontWeight": 700
      }
    },
    "value-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "'Segoe UI', system-ui, sans-serif",
        "fontSize": {
          "value": 18,
          "unit": "px"
        },
        "fontWeight": 600
      }
    }
  }
}
